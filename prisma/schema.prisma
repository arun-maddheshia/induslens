// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  legacyArticles Article[] @relation("LegacyArticleAuthor")
  edited         Article[] @relation("ArticleEditor")
}

// ─── Categories ──────────────────────────────────────────────────────

model Category {
  id          String   @id  // e.g. "India_and_the_SDGs"
  slug        String   @unique  // e.g. "India-and-the-SDGs"
  name        String
  description String   @db.Text
  isNews      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  order       Int      @default(1)

  articles    Article[]

  @@index([slug])
}

// ─── Articles ────────────────────────────────────────────────────────

enum ContentType {
  NEWS
  CONTENT_BLOCK
  ARTICLES
  ANCHOR
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Article {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Core content ──
  headline             String
  alternativeHeadline  String?
  excerpt              String
  description          String?
  articleBody          String   @db.Text
  pageContent          String?  @db.Text
  diveContent          String?  @db.Text

  // ── Classification ──
  contentType     ContentType    @default(NEWS)
  newsType        String?
  category        String?
  categoryId      String?
  categoryRef     Category?      @relation(fields: [categoryId], references: [id])
  categoryOrder   Int?           @default(1)  // Order within the category
  subCategories   String[]
  genre           String[]
  tags            String[]
  keywords        String[]
  language        String         @default("en")

  // ── SEO / Meta ──
  metaTitle       String
  metaDescription String
  slug            String   @unique
  url             String?
  canonicalUrl    String?

  // ── Publishing ──
  status      ArticleStatus @default(DRAFT)
  visibility  Boolean       @default(true)
  publishedAt DateTime?
  archivedAt  DateTime?
  expiresAt   DateTime?

  // ── Authorship ──
  authorId       String? // Now points to Author table
  author         Author? @relation("ArticleAuthor", fields: [authorId], references: [id])
  editorId       String?
  editor         User?   @relation("ArticleEditor", fields: [editorId], references: [id])
  legacyAuthorId String? // Keep existing User references
  legacyAuthor   User?   @relation("LegacyArticleAuthor", fields: [legacyAuthorId], references: [id])

  // ── Source ──
  agency     String?
  publisher  String?
  sourceType String?
  siteId     String?

  // ── Relations ──
  images               ArticleImage[]
  heroPlaylists        HeroPlaylist[]        @relation("HeroPlaylistArticle")
  otherStoriesPlaylists OtherStoriesPlaylist[] @relation("OtherStoriesPlaylistArticle")

  @@index([slug])
  @@index([status, publishedAt])
  @@index([category])
  @@index([categoryId])
  @@index([categoryId, categoryOrder])
  @@index([contentType])
}

model ArticleImage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  imageCategory      String
  imageCategoryValue String?
  imageDescription   String?
  imageUrl           String[]

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

// ─── Authors ────────────────────────────────────────────────────────

model Author {
  id        String   @id // Will preserve original _id from data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Core Info ──
  order           Int      @default(1)
  name            String
  aboutTheAnchor  String   @db.Text
  email           String?
  slug            String   @unique
  description     String?

  // ── Social Media Links ──
  facebookUrl   String?
  linkedinUrl   String?
  twitterUrl    String?
  instagramUrl  String?
  youtubeUrl    String?
  websiteUrl    String?
  authorUrl     String?

  // ── Meta Info ──
  contentType   String   @default("anchor")
  countryName   String?
  status        String   @default("Published")
  isContent     Boolean  @default(true)
  key           Int?     @unique
  siteId        String?

  // ── Publishing ──
  publishedAt   DateTime?

  // ── Legacy Fields ──
  anchorKey     String?
  shows         String[] @default([])

  // ── Relations ──
  images        AuthorImage[]
  articles      Article[] @relation("ArticleAuthor")

  @@index([slug])
  @@index([status])
  @@index([order])
}

model AuthorImage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  imageCategory      String
  imageCategoryValue String?
  imageDescription   String?
  imageUrl           String[]
  key                String?

  authorId String
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
}

model HeroPlaylist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Int
  articleId String
  article   Article @relation("HeroPlaylistArticle", fields: [articleId], references: [id], onDelete: Cascade)

  @@index([order])
}

model OtherStoriesPlaylist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Int
  articleId String
  article   Article @relation("OtherStoriesPlaylistArticle", fields: [articleId], references: [id], onDelete: Cascade)

  @@index([order])
}

