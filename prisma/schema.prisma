// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  legacyArticles Article[] @relation("LegacyArticleAuthor")
  edited         Article[] @relation("ArticleEditor")
}

// ─── Categories ──────────────────────────────────────────────────────

model Category {
  id          String   @id  // e.g. "India_and_the_SDGs"
  slug        String   @unique  // e.g. "India-and-the-SDGs"
  name        String
  description String   @db.Text
  isNews      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  order       Int      @default(1)

  articles    Article[]
  specials    Special[]

  @@index([slug])
}

// ─── Articles ────────────────────────────────────────────────────────

enum ContentType {
  NEWS
  CONTENT_BLOCK
  ARTICLES
  ANCHOR
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Article {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Core content ──
  headline             String
  alternativeHeadline  String?
  excerpt              String
  description          String?
  articleBody          String   @db.Text
  pageContent          String?  @db.Text
  diveContent          String?  @db.Text

  // ── Classification ──
  contentType     ContentType    @default(NEWS)
  newsType        String?
  category        String?
  categoryId      String?
  categoryRef     Category?      @relation(fields: [categoryId], references: [id])
  categoryOrder   Int?           @default(1)  // Order within the category
  subCategories   String[]
  genre           String[]
  tags            String[]
  keywords        String[]
  language        String         @default("en")

  // ── SEO / Meta ──
  metaTitle       String
  metaDescription String
  slug            String   @unique
  url             String?
  canonicalUrl    String?

  // ── Publishing ──
  status      ArticleStatus @default(DRAFT)
  visibility  Boolean       @default(true)
  publishedAt DateTime?
  archivedAt  DateTime?
  expiresAt   DateTime?

  // ── Authorship ──
  authorId       String? // Now points to Author table
  author         Author? @relation("ArticleAuthor", fields: [authorId], references: [id])
  editorId       String?
  editor         User?   @relation("ArticleEditor", fields: [editorId], references: [id])
  legacyAuthorId String? // Keep existing User references
  legacyAuthor   User?   @relation("LegacyArticleAuthor", fields: [legacyAuthorId], references: [id])

  // ── Source ──
  agency     String?
  publisher  String?
  sourceType String?
  siteId     String?

  // ── Relations ──
  images               ArticleImage[]
  heroPlaylists         HeroPlaylist[]         @relation("HeroPlaylistArticle")
  otherStoriesPlaylists OtherStoriesPlaylist[] @relation("OtherStoriesPlaylistArticle")
  indusTalesPlaylists   IndusTalesPlaylist[]   @relation("IndusTalesPlaylistArticle")
  specialArticles       SpecialArticle[]       @relation("SpecialArticleRef")

  @@index([slug])
  @@index([status, publishedAt])
  @@index([category])
  @@index([categoryId])
  @@index([categoryId, categoryOrder])
  @@index([contentType])
}

model ArticleImage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  imageCategory      String
  imageCategoryValue String?
  imageDescription   String?
  imageUrl           String[]

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

// ─── Authors ────────────────────────────────────────────────────────

model Author {
  id        String   @id // Will preserve original _id from data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Core Info ──
  order           Int      @default(1)
  name            String
  aboutTheAnchor  String   @db.Text
  email           String?
  slug            String   @unique
  description     String?

  // ── Social Media Links ──
  facebookUrl   String?
  linkedinUrl   String?
  twitterUrl    String?
  instagramUrl  String?
  youtubeUrl    String?
  websiteUrl    String?
  authorUrl     String?

  // ── Meta Info ──
  contentType   String   @default("anchor")
  countryName   String?
  status        String   @default("Published")
  isContent     Boolean  @default(true)
  key           Int?     @unique
  siteId        String?

  // ── Publishing ──
  publishedAt   DateTime?

  // ── Legacy Fields ──
  anchorKey     String?
  shows         String[] @default([])

  // ── Relations ──
  images        AuthorImage[]
  articles      Article[] @relation("ArticleAuthor")

  @@index([slug])
  @@index([status])
  @@index([order])
}

model AuthorImage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  imageCategory      String
  imageCategoryValue String?
  imageDescription   String?
  imageUrl           String[]
  key                String?

  authorId String
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
}

model HeroPlaylist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Int
  articleId String
  article   Article @relation("HeroPlaylistArticle", fields: [articleId], references: [id], onDelete: Cascade)

  @@index([order])
}

model OtherStoriesPlaylist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Int
  articleId String
  article   Article @relation("OtherStoriesPlaylistArticle", fields: [articleId], references: [id], onDelete: Cascade)

  @@index([order])
}

model IndusTalesPlaylist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Int
  articleId String
  article   Article @relation("IndusTalesPlaylistArticle", fields: [articleId], references: [id], onDelete: Cascade)

  @@index([order])
}

// ─── Videos ──────────────────────────────────────────────────────────

model Video {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Ordering ──
  order     Int      @default(1)

  // ── Identity (preserved from source) ──
  legacyId  String?  @unique  // original _id from dummy data

  // ── Core content ──
  name            String
  slug            String   @unique
  synopsis        String   @db.Text
  metaTitle       String
  metaDescription String   @db.Text

  // ── Video source ──
  contentId       String           // YouTube video ID or other source ID
  sourceType      String           // "youtube", "audio/mp3", etc.
  channelId       String?
  channelName     String?
  streamingSource String?
  duration        String?          // e.g. "22:41" — kept as string to match source

  // ── Classification ──
  contentType     String   @default("news")
  category        String?
  genre           String[]
  tags            String[]
  language        String   @default("en")
  languageCode    String?

  // ── Publishing ──
  status          String   @default("Published")
  isContent       Boolean  @default(true)
  key             Int?
  siteId          String?
  author          String?  // plain string author name from source (e.g. "IndusLens")
  publishedAt     DateTime?

  // ── Relations ──
  images          VideoImage[]

  @@index([slug])
  @@index([status])
  @@index([order])
  @@index([category])
}

model VideoImage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  imageCategory      String
  imageCategoryValue String?
  imageDescription   String?
  imageUrl           String[]
  key                String?

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
}

model Eminence {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Int      @default(1)
  legacyId  String?  @unique
  legacyKey Int?

  name        String
  slug        String   // role/title (e.g. "CEO, Chanel")
  excerpt     String   @db.Text
  pageContent String?  @db.Text
  countryName String?
  category    String?
  language    String   @default("en")
  status      String   @default("Published")
  isContent   Boolean  @default(true)
  siteId      String?

  facebookUrl  String?
  instagramUrl String?
  twitterUrl   String?
  linkedinUrl  String?
  websiteUrl   String?

  publishedAt DateTime?

  images EminenceImage[]

  @@index([status])
  @@index([order])
}

model EminenceImage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  imageCategory      String
  imageCategoryValue String?
  imageDescription   String?
  imageUrl           String[]
  key                String?

  eminenceId String
  eminence   Eminence @relation(fields: [eminenceId], references: [id], onDelete: Cascade)

  @@index([eminenceId])
}

// ─── Specials ─────────────────────────────────────────────────────────────────

model SpecialsPage {
  id          String   @id @default("main")
  title       String   @default("IndusLens Specials")
  description String   @db.Text @default("")
  updatedAt   DateTime @updatedAt
}

model Special {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  title       String
  description String   @db.Text @default("")
  order       Int      @default(1)

  categoryId  String?
  categoryRef Category? @relation(fields: [categoryId], references: [id])

  articles    SpecialArticle[]

  @@index([order])
}

model SpecialArticle {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  order     Int      @default(1)

  specialId String
  special   Special @relation(fields: [specialId], references: [id], onDelete: Cascade)

  articleId String
  article   Article @relation("SpecialArticleRef", fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([specialId, articleId])
  @@index([specialId, order])
}

